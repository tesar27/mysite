---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Yerbolat Tazhkeyev — Software Developer",
  description = "Personal portfolio of Yerbolat Tazhkeyev, a full-stack software developer specialising in modern web experiences.",
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0e0e0e" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="bg-[#0e0e0e] text-[#f0f0f0] font-sans antialiased">
    <slot />
  </body>
</html>
