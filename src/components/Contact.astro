---

---

<section id="contact" class="py-24 relative overflow-hidden">
  <!-- Glow -->
  <div
    class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-[#e8523a]/6 blur-[120px] pointer-events-none rounded-full"
  >
  </div>

  <div class="max-w-6xl mx-auto px-6 relative">
    <!-- Section label -->
    <div class="flex items-center gap-3 mb-4">
      <span class="w-10 h-px bg-[#e8523a]"></span>
      <span
        class="text-[#e8523a] text-sm font-semibold uppercase tracking-widest"
        >Contact</span
      >
    </div>

    <div class="grid md:grid-cols-2 gap-16 items-start">
      <!-- Left -->
      <div class="space-y-6">
        <h2 class="text-4xl md:text-5xl font-extrabold leading-tight">
          Let's build<br /><span class="text-[#e8523a]">something</span> great.
        </h2>
        <p class="text-[#8a8a8a] leading-relaxed max-w-sm">
          Whether you have a project in mind, a question, or just want to say hi
          — my inbox is open. I'll get back to you within 24 hours.
        </p>

        <!-- Direct channels -->
        <div class="space-y-4 pt-2">
          {
            [
              {
                label: "Email",
                value: "contact@yerbolat.com",
                href: "mailto:contact@yerbolat.com",
                icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" /></svg>`,
              },
              {
                label: "LinkedIn",
                value: "linkedin.com/in/yerbolat-tazhkeyev",
                href: "https://www.linkedin.com/in/yerbolat-tazhkeyev",
                icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
              },
            ].map((ch) => (
              <a href={ch.href} class="flex items-center gap-4 group">
                <span
                  class="w-10 h-10 rounded-xl bg-[#1e1e1e] border border-[#2a2a2a] flex items-center justify-center text-[#8a8a8a] group-hover:border-[#e8523a] group-hover:text-[#e8523a] transition-all duration-200 shrink-0"
                  set:html={ch.icon}
                />
                <div>
                  <p class="text-xs text-[#8a8a8a]">{ch.label}</p>
                  <p class="text-sm text-[#f0f0f0] group-hover:text-[#e8523a] transition-colors duration-200">
                    {ch.value}
                  </p>
                </div>
              </a>
            ))
          }
        </div>
      </div>

      <!-- Right: form -->
      <form
        class="space-y-4 bg-[#161616] border border-[#2a2a2a] rounded-2xl p-8"
        novalidate
      >
        <div class="grid sm:grid-cols-2 gap-4">
          <div class="space-y-1.5">
            <label for="name" class="text-xs text-[#8a8a8a] font-medium"
              >Name</label
            >
            <input
              id="name"
              name="name"
              type="text"
              placeholder="Jane Smith"
              required
              class="w-full bg-[#0e0e0e] border border-[#2a2a2a] rounded-xl px-4 py-3 text-sm text-[#f0f0f0] placeholder-[#8a8a8a]/50 focus:outline-none focus:border-[#e8523a] transition-colors duration-200"
            />
          </div>
          <div class="space-y-1.5">
            <label for="email" class="text-xs text-[#8a8a8a] font-medium"
              >Email</label
            >
            <input
              id="email"
              name="email"
              type="email"
              placeholder="jane@example.com"
              required
              class="w-full bg-[#0e0e0e] border border-[#2a2a2a] rounded-xl px-4 py-3 text-sm text-[#f0f0f0] placeholder-[#8a8a8a]/50 focus:outline-none focus:border-[#e8523a] transition-colors duration-200"
            />
          </div>
        </div>

        <div class="space-y-1.5">
          <label for="subject" class="text-xs text-[#8a8a8a] font-medium"
            >Subject</label
          >
          <input
            id="subject"
            name="subject"
            type="text"
            placeholder="Project inquiry"
            class="w-full bg-[#0e0e0e] border border-[#2a2a2a] rounded-xl px-4 py-3 text-sm text-[#f0f0f0] placeholder-[#8a8a8a]/50 focus:outline-none focus:border-[#e8523a] transition-colors duration-200"
          />
        </div>

        <div class="space-y-1.5">
          <label for="message" class="text-xs text-[#8a8a8a] font-medium"
            >Message</label
          >
          <textarea
            id="message"
            name="message"
            rows="5"
            placeholder="Tell me about your project..."
            required
            class="w-full bg-[#0e0e0e] border border-[#2a2a2a] rounded-xl px-4 py-3 text-sm text-[#f0f0f0] placeholder-[#8a8a8a]/50 focus:outline-none focus:border-[#e8523a] transition-colors duration-200 resize-none"
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full py-3.5 rounded-xl bg-[#e8523a] text-white font-semibold text-sm hover:bg-[#cf3e27] active:scale-[0.98] transition-all duration-200 shadow-lg shadow-[#e8523a]/20"
        >
          Send message →
        </button>
        <p class="text-xs text-center text-[#8a8a8a]">
          I'll reply within 24 hours.
        </p>
      </form>
    </div>
  </div>
</section>
