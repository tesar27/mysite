---
import type { Project } from "../data/projects";

interface Props {
  project: Project;
  index: number;
}

const { project, index } = Astro.props;

// Map image key → gradient palette for the visual placeholder
const palettes: Record<string, string> = {
  ecommerce: "from-[#e8523a]/20 to-[#ff8c69]/5",
  aichat: "from-[#6366f1]/20 to-[#a5b4fc]/5",
  taskmanager: "from-[#10b981]/20 to-[#6ee7b7]/5",
  fitness: "from-[#f59e0b]/20 to-[#fcd34d]/5",
  portfoliobuilder: "from-[#e8523a]/20 to-[#6366f1]/5",
  realestate: "from-[#06b6d4]/20 to-[#67e8f9]/5",
};

const gradient = palettes[project.image] ?? "from-[#e8523a]/20 to-[#1e1e1e]";

// Icon letters for the placeholder
const initials = project.title
  .split(" ")
  .slice(0, 2)
  .map((w) => w[0])
  .join("");
---

<article
  class="group bg-[#161616] border border-[#2a2a2a] rounded-2xl overflow-hidden hover:border-[#e8523a]/50 transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl hover:shadow-[#e8523a]/5 flex flex-col"
>
  <!-- Visual placeholder -->
  <div
    class={`relative h-44 bg-gradient-to-br ${gradient} flex items-center justify-center overflow-hidden`}
  >
    <span class="text-5xl font-black text-[#f0f0f0]/5 select-none absolute"
      >{project.title}</span
    >
    <span
      class="text-3xl font-black text-[#f0f0f0]/20 relative z-10 tracking-tighter"
      >{initials}</span
    >
    <!-- Project number badge -->
    <span
      class="absolute top-3 right-3 text-xs font-bold text-[#8a8a8a] bg-[#0e0e0e]/60 px-2.5 py-1 rounded-full"
    >
      {String(index + 1).padStart(2, "0")}
    </span>
  </div>

  <!-- Content -->
  <div class="p-6 flex flex-col flex-1 gap-3">
    <h3
      class="text-lg font-bold text-[#f0f0f0] group-hover:text-[#e8523a] transition-colors duration-200"
    >
      {project.title}
    </h3>
    <p class="text-sm text-[#8a8a8a] leading-relaxed flex-1">
      {project.description}
    </p>

    <!-- Tags -->
    <div class="flex flex-wrap gap-2 pt-1">
      {
        project.tags.map((tag) => (
          <span class="text-xs px-2.5 py-1 rounded-full bg-[#1e1e1e] border border-[#2a2a2a] text-[#8a8a8a]">
            {tag}
          </span>
        ))
      }
    </div>

    <!-- Links -->
    <div class="flex items-center gap-4 pt-2 border-t border-[#2a2a2a] mt-auto">
      {
        project.link && (
          <a
            href={project.link}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 text-xs font-semibold text-[#e8523a] hover:underline"
          >
            Live demo
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-3.5 h-3.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="2"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"
              />
            </svg>
          </a>
        )
      }
      {
        project.repo && (
          <a
            href={project.repo}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 text-xs font-semibold text-[#8a8a8a] hover:text-[#f0f0f0] transition-colors duration-200"
          >
            Source
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-3.5 h-3.5"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z" />
            </svg>
          </a>
        )
      }
    </div>
  </div>
</article>
