---

---

<section
  id="home"
  class="min-h-screen flex items-center relative overflow-hidden pt-24 pb-16"
>
  <!-- Background glow blobs -->
  <div
    class="absolute -top-40 -left-40 w-[480px] h-[480px] rounded-full bg-[#e8523a]/8 blur-[120px] pointer-events-none"
  >
  </div>
  <div
    class="absolute -bottom-20 -right-20 w-[360px] h-[360px] rounded-full bg-[#e8523a]/5 blur-[100px] pointer-events-none"
  >
  </div>

  <div
    class="max-w-6xl mx-auto px-6 w-full grid md:grid-cols-2 gap-12 items-center"
  >
    <!-- Left: text -->
    <div class="space-y-6 animate-fadeinup">
      <!-- Hello badge -->
      <div class="inline-flex items-center gap-2 text-sm text-[#8a8a8a]">
        <span class="w-8 h-px bg-[#e8523a]"></span>
        <span>Hello there</span>
        <span class="relative flex h-2 w-2">
          <span
            class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#e8523a] opacity-75"
          ></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-[#e8523a]"
          ></span>
        </span>
      </div>

      <!-- Heading -->
      <div>
        <p class="text-[#8a8a8a] text-lg mb-1">
          I'm <span class="text-[#f0f0f0] font-semibold">Yerlan</span>
        </p>
        <h1
          class="text-5xl md:text-6xl font-extrabold leading-tight tracking-tight"
        >
          Software
          <br />
          <span class="text-[#e8523a]">Developer</span>
          <span class="text-[#e8523a]">.</span>
        </h1>
      </div>

      <p class="text-[#8a8a8a] text-base leading-relaxed max-w-md">
        I craft fast, elegant digital experiences — from pixel-perfect UIs to
        resilient back-end systems. Let's build something great together.
      </p>

      <!-- CTAs -->
      <div class="flex flex-wrap gap-4 pt-2">
        <a
          href="#contact"
          class="inline-flex items-center gap-2 px-7 py-3 rounded-full bg-[#e8523a] text-white font-semibold text-sm hover:bg-[#cf3e27] active:scale-95 transition-all duration-200 shadow-lg shadow-[#e8523a]/25"
        >
          Got a project?
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-4 h-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"></path>
          </svg>
        </a>
        <a
          href="#about"
          class="inline-flex items-center gap-2 px-7 py-3 rounded-full border border-[#2a2a2a] text-[#f0f0f0] font-semibold text-sm hover:border-[#e8523a] hover:text-[#e8523a] active:scale-95 transition-all duration-200"
        >
          My resume
        </a>
      </div>

      <!-- Quick social links -->
      <div class="flex items-center gap-5 pt-2">
        {
          [
            {
              href: "#",
              label: "GitHub",
              icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/></svg>`,
            },
            {
              href: "#",
              label: "LinkedIn",
              icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
            },
            {
              href: "#",
              label: "Twitter",
              icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`,
            },
          ].map((s) => (
            <a
              href={s.href}
              aria-label={s.label}
              class="text-[#8a8a8a] hover:text-[#e8523a] transition-colors duration-200"
              set:html={s.icon}
            />
          ))
        }
      </div>
    </div>

    <!-- Right: avatar -->
    <div
      class="flex justify-center md:justify-end relative animate-fadeinup"
      style="animation-delay: 0.2s; opacity:0; animation-fill-mode: forwards;"
    >
      <!-- Decorative brackets -->
      <span
        class="absolute left-4 top-1/2 -translate-y-1/2 text-6xl font-thin text-[#e8523a]/40 select-none"
        >&lt;</span
      >
      <span
        class="absolute right-4 top-1/2 -translate-y-1/2 text-6xl font-thin text-[#e8523a]/40 select-none"
        >&gt;</span
      >

      <!-- Avatar circle -->
      <div class="relative w-64 h-64 md:w-80 md:h-80">
        <!-- Gradient ring -->
        <div
          class="absolute inset-0 rounded-full bg-gradient-to-br from-[#e8523a] via-[#e8523a]/40 to-transparent p-[3px]"
        >
          <div
            class="w-full h-full rounded-full bg-[#161616] flex items-center justify-center overflow-hidden"
          >
            <!-- Placeholder avatar (initials) — replace with <img> when you have a photo -->
            <div
              class="w-full h-full bg-gradient-to-br from-[#1e1e1e] to-[#0e0e0e] flex items-center justify-center"
            >
              <span class="text-7xl font-black text-[#e8523a]/20 select-none"
                >Y</span
              >
            </div>
          </div>
        </div>
        <!-- Floating badge -->
        <div
          class="absolute -bottom-3 left-1/2 -translate-x-1/2 bg-[#1e1e1e] border border-[#2a2a2a] rounded-full px-4 py-1.5 text-xs font-semibold text-[#f0f0f0] whitespace-nowrap shadow-xl"
        >
          ✦ Available for work
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <a
    href="#skills"
    class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1 text-[#8a8a8a] hover:text-[#e8523a] transition-colors duration-200 group"
  >
    <span class="text-xs tracking-widest uppercase">Scroll</span>
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="w-4 h-4 animate-bounce"
      fill="none"
      viewBox="0 0 24 24"
      stroke-width="2"
      stroke="currentColor"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="m19.5 8.25-7.5 7.5-7.5-7.5"></path>
    </svg>
  </a>
</section>
